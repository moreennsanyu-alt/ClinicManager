<Project>
  <PropertyGroup>
    <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <AspnetVersion>10.0.3</AspnetVersion>
    <EfcoreVersion>10.0.3</EfcoreVersion>
    <MicrosoftExtensionsVersion>10.0.3</MicrosoftExtensionsVersion>
    <CentralPackageVersionOverrideEnabled>false</CentralPackageVersionOverrideEnabled>
  </PropertyGroup>
 
  <ItemGroup>
    <PackageVersion Include="coverlet.collector" Version="8.0.0" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="nunit" Version="4.5.1" />
    <PackageVersion Include="NUnit.Analyzers" Version="4.12.0" />
    <PackageVersion Include="NUnit3TestAdapter" Version="6.2.0" />
    <PackageVersion Include="Shouldly" Version="4.3.0" />

    <PackageVersion Include="Microsoft.EntityFrameworkCore.Sqlite" Version="$(EfcoreVersion)" />

    <PackageVersion Include="PolySharp" Version="1.15.0" />
    <PackageVersion Include="Humanizer.Core" Version="3.0.1" />
    <PackageVersion Include="System.ValueTuple" Version="4.6.2" />
    <PackageVersion Include="Utf8StringInterpolation" Version="1.3.2" />
    
    <PackageVersion Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.5.2" />
    <PackageVersion Include="Microsoft.Testing.Extensions.TrxReport" Version="2.0.1" />


    <PackageVersion Include="WixSharp" Version="1.26.0" />
    <PackageVersion Include="WixSharp.bin" Version="1.26.0" />
    <PackageVersion Include="WixSharp.wix.bin" Version="3.14.1" />
    
    <PackageVersion Include="ThisAssembly.Constants" Version="1.4.3" />
    

    <PackageVersion Include="FlaUI.UIA3.Signed" Version="5.0.0" />
    <PackageVersion Include="FlaUI.Core.Signed" Version="5.0.0" />
    <PackageVersion Include="FlaUI.TestUtilities" Version="5.0.0" />
     
    <PackageVersion Include="Prism.Core" Version="8.1.97" />
    <PackageVersion Include="Prism.Wpf" Version="8.1.97" />
    <PackageVersion Include="Prism.DryIoc" Version="8.1.97" />
    <PackageVersion Include="SingleInstanceCore" Version="2.2.2" />

    <PackageVersion Include="ServiceStack" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Text" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Common" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Interfaces" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Client" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.OrmLite" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Server" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Api.OpenApi" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.AspNetCore.OpenApi" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.HttpClient" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Kestrel" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.OrmLite.Sqlite" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Jobs" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.Extensions" Version="10.0.6" />
    <PackageVersion Include="ServiceStack.OrmLite.Sqlite.Data" Version="10.0.6" />
  </ItemGroup>
  
</Project>
